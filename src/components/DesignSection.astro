---
import ProjectCard from './ProjectCard';

const designRows = [
  {
    left: {
      slug: 'bioderma', title: 'Bioderma', subtitle: 'Brand Guidelines',
      image: '/images/polaroid.png', category: 'design', description: '', tags: [],
    },
    leftSize: '60%',
    right: {
      slug: 'social-assets', title: 'Social Assets', subtitle: 'Digital Design',
      image: '/images/polaroid.png', category: 'design', description: '', tags: [],
    },
    rightSize: '40%',
  },
  {
    left: {
      slug: 'ahorro', title: 'Ahorro', subtitle: 'App UI Design',
      image: '/images/polaroid.png', category: 'design', description: '', tags: [],
    },
    leftSize: '40%',
    right: {
      slug: '888-branding', title: '888', subtitle: 'Brand Identity',
      image: '/images/polaroid.png', category: 'design', description: '', tags: [],
    },
    rightSize: '60%',
  },
];
---

<section class="max-w-[1280px] mx-auto px-6 lg:px-20 py-20">
  <!-- Section header -->
  <div class="flex items-baseline gap-3 mb-4">
    <span class="text-3xl md:text-4xl lg:text-5xl font-bold">
      Design
    </span>
  </div>
  <hr class="section-divider mb-10" />

  <!-- Project rows -->
  <div class="flex flex-col gap-4">
    {designRows.map((row) => (
      <div class="flex flex-col md:flex-row gap-4 h-auto md:h-72 lg:h-80">
        <div class="w-full md:w-[var(--left-size)] h-64 md:h-full" style={`--left-size: ${row.leftSize}`}>
          <ProjectCard
            client:load
            project={row.left as any}
            className="h-full"
          />
        </div>
        <div class="w-full md:w-[var(--right-size)] h-64 md:h-full" style={`--right-size: ${row.rightSize}`}>
          <ProjectCard
            client:load
            project={row.right as any}
            className="h-full"
          />
        </div>
      </div>
    ))}
  </div>
</section>

<hr class="section-divider max-w-[1280px] mx-auto px-6 lg:px-20" />
