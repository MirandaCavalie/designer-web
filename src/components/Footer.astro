---
import BackToTop from './BackToTop';
---

<footer id="contact" class="max-w-[1280px] mx-auto px-6 lg:px-20 py-20">
  <!-- Back to top -->
  <div class="flex justify-center mb-16">
    <BackToTop client:load />
  </div>

  <!-- Contact section -->
  <div class="flex flex-col lg:flex-row items-start lg:items-end justify-between gap-10">
    <!-- Left: heading + email -->
    <div class="space-y-4">
      <h2
        class="text-3xl md:text-4xl font-normal"
        style="font-family: 'DM Serif Display', Georgia, serif;"
      >
        Get in touch
      </h2>
      <p class="text-sm text-gray-500 max-w-xs">
        Open to freelance projects, collaborations, and creative conversations.
      </p>
      <a
        href="mailto:fernanda@puntoyraya.com"
        class="inline-block text-lg font-medium underline underline-offset-4 hover:text-gray-500 transition-colors duration-200"
      >
        fernanda@puntoyraya.com
      </a>
    </div>

    <!-- Right: social links -->
    <div class="flex flex-col items-start lg:items-end gap-3">
      <p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Find me on</p>
      <div class="flex gap-4">
        {[
          { label: 'Instagram', href: 'https://instagram.com/puntoyraya' },
          { label: 'Behance', href: 'https://behance.net' },
          { label: 'LinkedIn', href: 'https://linkedin.com' },
        ].map(({ label, href }) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium border-b border-transparent hover:border-black transition-all duration-200 pb-0.5"
          >
            {label}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="mt-16 pt-6 border-t border-[#E0E0E0] flex flex-col sm:flex-row justify-between gap-2 text-xs text-gray-400">
    <span>© {new Date().getFullYear()} Fernanda Jara Meza. All rights reserved.</span>
    <span>Designed & built with care.</span>
  </div>
</footer>
